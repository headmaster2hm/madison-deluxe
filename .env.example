# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook — from `stripe listen` locally or Stripe Dashboard in production
# Webhook endpoint: /api/stripe/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Resend API key for sending confirmation emails
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender email (must be verified in Resend)
RESEND_FROM_EMAIL=Madison Deluxe <hello@madisondeluxe.com>

# Studio dashboard (hidden at /studio — not linked from public site)
ADMIN_PASSWORD=your_secure_studio_password
# Optional: separate signing secret for session cookies
# ADMIN_SECRET=your_random_secret_string
